#!/usr/bin/env bash
# Local fence: format + clippy (same -D warnings as CI).
# The full test suite stays in CI (~1 min); this hook skips it so
# commits don't stall. If clippy or fmt complains, CI would have
# rejected the push anyway — fail fast here.
#
# Enable once per clone:
#   git config core.hooksPath .githooks
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

echo "==> cargo fmt --check"
cargo fmt --all -- --check

echo "==> cargo clippy --workspace --all-targets --features full -- -D warnings"
cargo clippy --workspace --all-targets --features full --no-deps -- -D warnings

echo "==> pre-commit OK"
